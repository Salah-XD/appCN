{
  "name": "@app-cn/cli",
  "version": "0.1.0",
  "description": "Init + add CLI for appCN. RN-aware shadcn registry helper for Expo and bare React Native.",
  "keywords": [
    "react-native",
    "expo",
    "nativewind",
    "shadcn",
    "cli",
    "appcn"
  ],
  "author": "Salah-XD",
  "license": "MIT",
  "homepage": "https://appcn.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/Salah-XD/appCN.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/Salah-XD/appCN/issues"
  },
