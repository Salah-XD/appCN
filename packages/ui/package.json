    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "expo-haptics": "*",
    "nativewind": ">=4",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*"
  },
  "peerDependenciesMeta": {
    "expo-haptics": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appcn/tsconfig": "workspace:*",
    "nativewind": "^4.1.23",
    "typescript": "^5.7.3"
