{
  "name": "@appcn/ui",
  "version": "0.1.0",
  "description": "Copy-paste mobile components for React Native + Expo. Motion-first, dark-by-default, with a featured AI-native collection.",
  "keywords": [
    "react-native",
    "expo",
    "nativewind",
    "shadcn",
    "components",
    "ui",
    "ai",
    "mobile",
    "reanimated"
  ],
  "author": "Salah-XD",
  "license": "MIT",
  "homepage": "https://appcn.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Salah-XD/appCN.git",
    "directory": "packages/ui"
  },
  "bugs": {
    "url": "https://github.com/Salah-XD/appCN/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx",
    "./ai/*": "./src/ai/*.tsx",
    "./lib/*": "./src/lib/*.ts",
    "./tailwind-preset": "./tailwind.preset.js",
    "./global.css": "./src/global.css"
  },
  "files": [
    "src",
    "tailwind.preset.js",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "@react-three/fiber": ">=9",
    "expo-gl": "*",
    "expo-haptics": "*",
    "nativewind": ">=4",
    "react": "*",
    "react-native": "*",
    "react-native-gesture-handler": "*",
    "react-native-reanimated": "*",
    "three": ">=0.170"
  },
  "peerDependenciesMeta": {
    "expo-haptics": {
      "optional": true
    },
    "@react-three/fiber": {
      "optional": true
    },
    "expo-gl": {
      "optional": true
    },
    "three": {
      "optional": true
    }
  },
  "devDependencies": {
    "@appcn/tsconfig": "workspace:*",
    "@react-three/fiber": "^9.6.1",
    "@types/three": "^0.184.0",
    "expo-gl": "~16.0.10",
    "nativewind": "^4.1.23",
    "three": "^0.184.0",
    "typescript": "^5.7.3"
  }
}
