    "./lib/*": "./src/lib/*.ts",
    "./tailwind-preset": "./tailwind.preset.js",
    "./global.css": "./src/global.css"
  },
  "scripts": {
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
